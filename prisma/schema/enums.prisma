// System role — kept for backward compatibility with BetterAuth's User table.
// Drives platform-wide capability gates (e.g. admin console, teacher tools).
enum Role {
  ADMIN
  TEACHER
  STUDENT
}

// Account-level permission tier — drives what the user can do inside their
// OWN workspace / account (projects, members, billing). Mirrors the
// frontend's `SessionUser.role` union ("owner" | "admin" | "editor" | "viewer").
enum AccountRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

// Lifecycle / workflow state of a Project.
// Mirrors the frontend's `ProjectStatus` union after API mapping
// (e.g. `IN_PROGRESS` ⇄ `in-progress`, `IN_REVIEW` ⇄ `review`).
enum ProjectStatus {
  DRAFT
  PLANNING
  IN_PROGRESS
  IN_REVIEW
  LAUNCHED
  PAUSED
  ARCHIVED
}

enum DeliverableStatus {
  PENDING
  IN_PROGRESS
  IN_REVIEW
  COMPLETE
  BLOCKED
}

// Activity feed events.
enum ActivityType {
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_STATUS_CHANGED
  DELIVERABLE_CREATED
  DELIVERABLE_UPDATED
  DELIVERABLE_STATUS_CHANGED
  MEMBER_ADDED
  MEMBER_REMOVED
  COMMENT_POSTED
  FILE_UPLOADED
  BILLING_EVENT
  AUTH_LOGIN
  AUTH_2FA_VERIFIED
  AUTH_PASSWORD_RESET
  AUTH_EMAIL_VERIFIED
}

// Two-factor authentication challenge method.
enum TwoFactorMethod {
  TOTP
  EMAIL_OTP
  RECOVERY_CODE
}

// Purpose codes for one-time codes (email verification, password reset,
// 2FA email-OTP). Mirrors the frontend `OtpPurpose` union.
enum OtpPurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
  TWO_FACTOR_EMAIL
}

// Type of legal document we publish.
enum LegalDocumentType {
  PRIVACY_POLICY
  TERMS_OF_SERVICE
  COOKIE_POLICY
  ACCEPTABLE_USE
  SERVICE_POLICY
}

// Lifecycle of a legal document version.
enum LegalDocumentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Source attribution captured on registration.
enum ReferralSourceType {
  DIRECT
  ORGANIC_SEARCH
  PAID_AD
  SOCIAL
  REFERRAL
  EMAIL_CAMPAIGN
  OTHER
}
