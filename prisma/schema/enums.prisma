/// Reason code captured when a ticket moves to RESOLVED or CLOSED.
/// Drives CSAT surveys and macro-classification reports (S7).
enum ResolutionCode {
  FIXED
  WORKAROUND
  DUPLICATE
  WONT_FIX
  CUSTOMER_RESPONDED
  ESCALATED_TO_ENGINEERING
  BILLING_ADJUSTMENT
  OTHER
}

/// Sentiment inferred from the customer's last visible message (S1 dashboard
/// + S3 workspace sentiment strip). NULL means "unknown / neutral".
enum CustomerSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  AT_RISK
}

/// Lifecycle state of an organization's support relationship (S5 profile).
enum AccountStatus {
  ACTIVE
  AT_RISK
  CHURNING
  DORMANT
  CLOSED
}

/// Visibility tier for internal notes — INTERNAL_TEAM is staff-only,
/// LEADERSHIP is restricted to ADMIN+OWNER, PRIVATE is the note author only.
enum NoteVisibility {
  INTERNAL_TEAM
  LEADERSHIP
  PRIVATE
}

/// Severity bucket that drives SLA timers + escalation radar ordering.
enum SlaSeverity {
