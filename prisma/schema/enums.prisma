// System role — kept for backward compatibility with BetterAuth's User table.
// Drives platform-wide capability gates (e.g. admin console, teacher tools).
enum Role {
  ADMIN
  TEACHER
  STUDENT
}

// Account-level permission tier — drives what the user can do inside their
// OWN workspace / account (projects, members, billing). Mirrors the
// frontend's `SessionUser.role` union ("owner" | "admin" | "editor" | "viewer").
enum AccountRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

// Lifecycle / workflow state of a Project.
// Mirrors the frontend's `ProjectStatus` union after API mapping
// (e.g. `IN_PROGRESS` ⇄ `in-progress`, `IN_REVIEW` ⇄ `review`).
enum ProjectStatus {
  DRAFT
  PLANNING
  IN_PROGRESS
  IN_REVIEW
  LAUNCHED
  PAUSED
  ARCHIVED
}

enum DeliverableStatus {
  PENDING
  IN_PROGRESS
  IN_REVIEW
  COMPLETE
  BLOCKED
}

// Activity feed events.
enum ActivityType {
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_STATUS_CHANGED
  DELIVERABLE_CREATED
  DELIVERABLE_UPDATED
  DELIVERABLE_STATUS_CHANGED
  MEMBER_ADDED
  MEMBER_REMOVED
  COMMENT_POSTED
  FILE_UPLOADED
  BILLING_EVENT
  AUTH_LOGIN
  AUTH_2FA_VERIFIED
  AUTH_PASSWORD_RESET
  AUTH_EMAIL_VERIFIED
}

// Two-factor authentication challenge method.
enum TwoFactorMethod {
  TOTP
  EMAIL_OTP
  RECOVERY_CODE
}

// Purpose codes for one-time codes (email verification, password reset,
// 2FA email-OTP). Mirrors the frontend `OtpPurpose` union.
enum OtpPurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
  TWO_FACTOR_EMAIL
}

// Type of legal document we publish.
enum LegalDocumentType {
  PRIVACY_POLICY
  TERMS_OF_SERVICE
  COOKIE_POLICY
  ACCEPTABLE_USE
  SERVICE_POLICY
}

// Lifecycle of a legal document version.
enum LegalDocumentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Source attribution captured on registration.
enum ReferralSourceType {
  DIRECT
  ORGANIC_SEARCH
  PAID_AD
  SOCIAL
  REFERRAL
  EMAIL_CAMPAIGN
  OTHER
}

// ----------------------------------------------------------------------------
// Customer portal enums (C1–C10)
// ----------------------------------------------------------------------------

/// Onboarding step completion state.
enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

/// High-level health flag on a customer project.
enum ProjectHealth {
  ON_TRACK
  AT_RISK
  BLOCKED
}

/// Phase of a customer-facing project.
enum ProjectPhase {
  DISCOVERY
  DESIGN
  BUILD
  REVIEW
  LAUNCH
  MAINTENANCE
}

/// Approval lifecycle states.
enum ApprovalStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
  EXPIRED
  CANCELLED
}

/// Invoice lifecycle (mirrors the standard customer-billing pipeline).
enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

/// Subscription cadence.
enum MaintenanceCadence {
  MONTHLY
  QUARTERLY
  ANNUAL
}

/// Status of a maintenance subscription.
enum MaintenanceSubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

/// Type of maintenance request the customer submits.
enum MaintenanceRequestType {
  UPDATE
  BUG_FIX
  CONTENT_EDIT
  PERFORMANCE
  SECURITY
  BACKUP_RESTORE
  CONSULT
}

/// Ticket priority used by both customer and staff sides.
enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

/// Ticket lifecycle.
enum TicketStatus {
  OPEN
  PENDING_CUSTOMER
  PENDING_STAFF
  RESOLVED
  CLOSED
}

/// Visibility flag for ticket messages — INTERNAL never leaves staff.
enum TicketMessageVisibility {
  CUSTOMER
  INTERNAL
}

/// Notification category (drives grouping in the centre page).
enum NotificationKind {
  PROJECT
  APPROVAL
  INVOICE
  MAINTENANCE
  SUPPORT
  SECURITY
  ACCOUNT
}

/// Status of an async data-export job.
enum DataExportStatus {
  QUEUED
  RUNNING
  READY
  FAILED
  EXPIRED
}

/// Communication preference.
enum CommunicationPreference {
  EMAIL
  PHONE
  SLACK
  TEAMS
}

/// Storage state for a private uploaded file asset.
enum FileAssetStatus {
  PENDING
  READY
  SCANNING
  INFECTED
  ARCHIVED
}
