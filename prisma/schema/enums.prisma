  CONTENT_ESCALATED
  MEDIA_QUARANTINED
  MEDIA_CLEARED
  TESTIMONIAL_CONSENT_VERIFIED
  CLIENT_PUBLICATION_APPROVED
  CLIENT_PUBLICATION_REVOKED
}

