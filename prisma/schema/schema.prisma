// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// In Prisma 7 the `schema` config points at a directory; every `.prisma` file
// in it is automatically merged. We split the models by domain
// (enums, auth, domain, customer, legal) for maintainability.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
